    "surrogate_model.onnx",
    "scalers.json",
    "golden_seed.json",
    "custom-elements.json"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs"
  },
  "dependencies": {
    "onnxruntime-web": "^1.21.0"
  },
