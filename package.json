    "onnxruntime",
    "surrogate-model",
    "physiology",
    "respiratory"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/filipneo/pneumonia-surrogate.git"
  },
  "main": "dist/pneumonia-surrogate.js",
